{
  "run_name": "cifar_tiny",
  "seed": 2027,
  "dataset": {
    "name": "fake_cifar",
    "num_samples": 1024,
    "num_classes": 10,
    "batch_size": 64
  },
  "model": {
    "name": "tiny_cnn"
  },
  "fed": {
    "num_clients": 8,
    "rounds": 3,
    "local_epochs": 1,
    "partition": "dirichlet",
    "dirichlet_alpha": 0.5,
    "clients_per_round": 8,
    "lr": 0.05
  },
  "layout": {
    "template_policy": "bucketed_fixed"
  }
}

